"""
环境配置文件示例
"""

# 应用配置
APP_NAME=客户运营中台
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customer_sys
DATABASE_ECHO=False

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production-please-use-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
